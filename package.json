{
  "name": "zorb",
  "description": "Declarative local workflow runner",
  "version": "0.0.5",
  "license": "MIT",
  "type": "module",
  "bin": {
    "zorb": "./bin/zorb.cjs"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun scripts/build.ts",
    "prepack": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "files": [
    "bin",
    "dist",
    "zorb.schema.json"
  ],
  "dependencies": {
    "minimist": "^1.2.8",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/minimist": "^1.2.5",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "bun": ">=1.3.13"
  }
}
