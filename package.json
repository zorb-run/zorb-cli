{
  "name": "zorb",
  "description": "Declarative local workflow runner",
  "version": "0.0.5",
  "license": "MIT",
  "type": "module",
  "bin": {
    "zorb": "./bin/zorb.cjs"
  },
  "exports": {
    "./action": {
      "types": "./dist/action.d.ts",
      "import": "./dist/action.js",
      "default": "./dist/action.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun scripts/build.ts",
    "build:public": "tsc -p tsconfig.public.json",
    "prepack": "bun run build",
    "test:unit": "bun test",
    "test:integration": "./integration-tests/run.sh",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "validate:schema": "bun scripts/validate-schema.ts"
  },
  "files": [
    "bin",
    "dist",
    "zorb.schema.json"
  ],
  "dependencies": {
    "minimist": "^1.2.8",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/minimist": "^1.2.5",
    "ajv": "^8.20.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "bun": ">=1.3.13"
  }
}
