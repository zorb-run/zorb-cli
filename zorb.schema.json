{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zorb.run/zorb.schema.json",
  "title": "Zorb Workflow",
  "description": "Schema for zorb.yml workflow files",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "description": "Workflow schema version. Optional, defaults to 1. Reserved for future schema changes.",
      "type": "integer",
      "enum": [1],
      "default": 1
    },
    "defaults": {
      "description": "Top-level defaults for step execution",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "run": {
          "description": "Defaults for run: steps",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "shell": {
              "description": "Default shell for run: steps (defaults to $SHELL)",
              "type": "string"
            },
            "cwd": {
              "description": "Default working directory for run: steps",
              "type": "string"
            },
            "env": {
              "description": "Default environment variables for run: steps",
              "$ref": "#/$defs/env"
            }
          }
        }
      }
    },
    "env": {
      "description": "Top-level environment variables, inherited by all tasks and steps",
      "$ref": "#/$defs/env"
    },
    "tasks": {
      "description": "Task definitions",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/task"
      },
      "minProperties": 1
    }
  },
  "required": ["tasks"],
  "$defs": {
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Key-value map of environment variables"
    },
    "with": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }]
      },
      "description": "Key-value map of inputs passed to an action"
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "description": "Description shown in `zorb list` output",
          "type": "string"
        },
        "inputs": {
          "description": "Task-level input definitions",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/input"
          }
        },
        "defaults": {
          "description": "Task-level defaults for step execution (overrides top-level defaults)",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "run": {
              "description": "Defaults for run: steps within this task",
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "shell": {
                  "description": "Default shell for run: steps in this task",
                  "type": "string"
                },
                "cwd": {
                  "description": "Default working directory for run: steps in this task",
                  "type": "string"
                },
                "env": {
                  "description": "Default environment variables for run: steps in this task",
                  "$ref": "#/$defs/env"
                }
              }
            }
          }
        },
        "env": {
          "description": "Task-level environment variables, inherited by all steps",
          "$ref": "#/$defs/env"
        },
        "steps": {
          "description": "Ordered list of steps to execute",
          "type": "array",
          "items": {
            "$ref": "#/$defs/step"
          },
          "minItems": 1
        }
      },
      "required": ["steps"]
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "description": "Description of the input",
          "type": "string"
        },
        "type": {
          "description": "Type of the input value",
          "type": "string",
          "enum": ["string", "boolean", "number"]
        },
        "required": {
          "description": "Whether the input must be provided",
          "type": "boolean"
        },
        "default": {
          "description": "Default value if not provided",
          "oneOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }]
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [{ "required": ["run"] }, { "required": ["uses"] }],
      "properties": {
        "id": {
          "description": "Unique identifier for this step, used to reference outputs in expressions",
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_-]*$"
        },
        "name": {
          "description": "Display name for the step, shown in CLI output",
          "type": "string"
        },
        "run": {
          "description": "Shell command to execute. Multi-line commands (YAML |) execute as a single shell invocation via $SHELL -c. Note: ${{ }} expressions are NOT evaluated inside run: strings, and zorb does not auto-inject any env vars — the command is passed to the shell unmodified. To use an input, step output, or expression result, declare it explicitly under env: (at workflow, task, or step level) using ${{ }}, then read it natively as $NAME in the shell.",
          "type": "string"
        },
        "uses": {
          "description": "Code action or workflow task reference. Resolves as: local file (./path.action), NPM package (@scope/package/action), or cross-file workflow (./other/zorb.taskname)",
          "type": "string"
        },
        "with": {
          "description": "Inputs passed to a uses: action",
          "$ref": "#/$defs/with"
        },
        "env": {
          "description": "Step-level environment variables (overrides task and top-level env)",
          "$ref": "#/$defs/env"
        },
        "cwd": {
          "description": "Working directory for run: steps (defaults to directory containing zorb.yml)",
          "type": "string"
        },
        "shell": {
          "description": "Override shell for this run: step",
          "type": "string"
        },
        "docker": {
          "description": "Run the command inside a Docker container. Short form: image name string. Long form: object with image and options",
          "oneOf": [
            {
              "type": "string",
              "description": "Docker image name (short form)"
            },
            {
              "$ref": "#/$defs/docker"
            }
          ]
        },
        "timeout": {
          "description": "Maximum duration the step is allowed to run before it is killed. Format: e.g. '500ms', '30s', '5m', '1h'.",
          "type": "string",
          "pattern": "^\\s*(?:0*[1-9][0-9]*(?:\\.[0-9]+)?|0*\\.0*[1-9][0-9]*)\\s*(?:ms|s|m|h)\\s*$"
        },
        "retries": {
          "description": "Number of additional attempts after the first if the step fails. Total attempts = retries + 1.",
          "type": "integer",
          "minimum": 0
        },
        "backoff": {
          "description": "Delay strategy between retries. 'linear' delays grow by 1s each attempt; 'exponential' doubles each attempt (base 1s).",
          "type": "string",
          "enum": ["linear", "exponential"]
        }
      },
      "dependentSchemas": {
        "with": {
          "required": ["uses"]
        },
        "cwd": {
          "required": ["run"]
        },
        "shell": {
          "required": ["run"]
        },
        "docker": {
          "required": ["run"]
        },
        "backoff": {
          "required": ["retries"]
        }
      }
    },
    "docker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image"],
      "properties": {
        "image": {
          "description": "Docker image to use",
          "type": "string"
        },
        "volumes": {
          "description": "Volume mounts (e.g. [\"/host:/container\"])",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "network": {
          "description": "Docker network mode",
          "type": "string"
        },
        "workdir": {
          "description": "Working directory inside the container (-w flag)",
          "type": "string"
        },
        "platform": {
          "description": "Target platform (e.g. linux/amd64)",
          "type": "string"
        },
        "entrypoint": {
          "description": "Override the container entrypoint",
          "type": "string"
        },
        "pull": {
          "description": "Image pull policy",
          "type": "string",
          "enum": ["always", "never", "if-not-present"]
        }
      }
    }
  }
}
